# ShapeTree
apps/shape-tree-api/.env
apps/shape-tree-web/.env

# Mutable Scribe-compatible store (`data.path` pointing at checkout root keeps this subtree local only)
*.shape-tree/
apps/ShapeTreeApp/project.local.yml

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Xcode - generated project files (xcodegen regenerates from project.yml)
*.xcodeproj
*.xcworkspace
xcuserdata/
xcshareddata/IDEFindNavigatorScopes.plist
UserInterfaceState.xcuserstate
IDEWorkspaceChecks.plist
*.xcuserstate

# Xcode - build artifacts
DerivedData/
Build/
*.xcarchive

# Xcode - playground
timeline.xctimeline
playground.xcworkspace

# SwiftPM build artifacts
*.build
*.swiftpm
Packages/
*.xcodeproj
*.xcworkspace

# SwiftPM coverage artifacts
*.profdata
*.profraw
coverage.lcov

Package.resolved

# shape-tree-web wasm client build output (generated by Scripts/build-core.sh)
apps/shape-tree-web/Sources/ShapeTreeWebAssets/client/
# example site wasm output (generated by examples/st-gen-markdown/)
examples/st-gen-markdown/content/
*.wasm
