# Server (ShapeTreeWeb)
HOSTNAME=127.0.0.1
PORT=8080
STATIC_ROOT=dist
# Local dev: build WASM on `swift run`. Docker compose overrides this to 1 (assets baked into the image).
SKIP_SHAPE_TREE_WEB_BUILD=0

OTEL_HOST=127.0.0.1
OTEL_PORT=42070

# Public URL used in magic-link emails.
SITE_URL=http://127.0.0.1:8080

# Optional Postgres. When set, email login + fit-viewer protection are enabled.
# Docker compose overrides PGHOST to postgres.
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=shape_tree
PGPASSWORD=shape_tree
PGDATABASE=shape_tree
PGSSLMODE=disable

# Optional SMTP. Required only when sending login links (not at server boot).
# SMTP_HOST=smtp.mail.me.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_TLS=startTLS

AUTH_TOKEN_TTL_MINUTES=15
AUTH_SESSION_TTL_HOURS=336

OTEL_SERVICE_NAME=shape-tree-web
OTEL_EXPORTER_OTLP_BASE_ENDPOINT=http://127.0.0.1:4318
OTEL_SDK_DISABLED=false

# shape-tree-web-builder (used automatically by `swift run ShapeTreeWeb` when SKIP_SHAPE_TREE_WEB_BUILD=0)
SWIFT_SDK_ID=swift-6.3.2-RELEASE_wasm-embedded
SWIFT_BUILD_CONFIGURATION=debug

# Docker maps host 42069 → container PORT (8080), 42070 → OTEL_PORT.
# Add users: swift run shape-tree-add-user you@example.com
