# Server (ShapeTreeWeb)
HOSTNAME=127.0.0.1
PORT=8080
STATIC_ROOT=dist
# Local dev: build WASM on `swift run`. Docker compose overrides this to 1 (assets baked into the image).
SKIP_SHAPE_TREE_WEB_BUILD=0

ADMIN_HOST=127.0.0.1
ADMIN_PORT=42070

OTEL_SERVICE_NAME=shape-tree-web
OTEL_EXPORTER_OTLP_BASE_ENDPOINT=http://127.0.0.1:4318
OTEL_SDK_DISABLED=false

# shape-tree-web-builder (used automatically by `swift run ShapeTreeWeb` when SKIP_SHAPE_TREE_WEB_BUILD=0)
SWIFT_SDK_ID=swift-6.3.2-RELEASE_wasm-embedded
SWIFT_BUILD_CONFIGURATION=debug

# Docker maps host 42069 → container PORT (8080), 42070 → ADMIN_PORT.
