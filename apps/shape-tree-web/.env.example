HOST=0.0.0.0
PORT=42069

ADMIN_HOST=0.0.0.0
ADMIN_PORT=42070

CONTENT_PATH=/Examples/content
INDEX_SLUG=Home

# Optional: public URL used in auth links. Defaults to http://HOST:PORT.
SITE_URL=http://localhost:42069

# Optional: comma-separated list of content directories to protect with login.
# Example: AUTH_PRIVATE_DIRECTORIES=Private,Notes/Secret
AUTH_PRIVATE_DIRECTORIES=

# Optional Postgres configuration. If all PG* values are set, email login is enabled.
# When running via docker-compose, these are overridden by environment variables.
# PGHOST=postgres
# PGPORT=5432
# PGUSER=shape_tree
# PGPASSWORD=shape_tree
# PGDATABASE=shape_tree
# PGSSLMODE=disable

# Optional SMTP configuration. Required to send login links.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_TLS=startTLS

OTEL_SERVICE_NAME=shape-tree-web
OTEL_EXPORTER_OTLP_BASE_ENDPOINT=http://jaeger:4318
OTEL_SDK_DISABLED=false
